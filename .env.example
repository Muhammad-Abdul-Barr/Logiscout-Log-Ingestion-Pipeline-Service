# ══════════════════════════════════════════════════════════
# LogiScout Logs Ingestion Pipeline — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── OLAP / ClickHouse (HTTP native — no JDBC) ────────────
OLAP_HOST=your-clickhouse-host
OLAP_PORT=olap-port
OLAP_DATABASE=olap-database-name
OLAP_TABLE=table-name
OLAP_USER=default
OLAP_PASSWORD=your-password

# ── Qdrant ────────────────────────────────────────────────
# Use "qdrant" (the docker-compose service name) when running in Docker
# Use "http://localhost:6333" for local development
QDRANT_URL=http://qdrant:6333

# ── Scheduler ─────────────────────────────────────────────
FETCH_INTERVAL_MINUTES=5
FETCH_BATCH_SIZE=1000
WATERMARK_PATH=/app/data/.watermark

# ── Gatekeeper (optional — defaults in config.py) ────────
# SEVERITY_THRESHOLD=7
# DEPLOY_WINDOW_MINUTES=60
# COLD_START_BASELINE_COUNT=3
# MAX_SEMANTIC_CHARS=2000
# UPSERT_BATCH_SIZE=100

# ── Fault Tolerance (optional — defaults in config.py) ───
# RETRY_MAX_ATTEMPTS=3
# RETRY_BACKOFF_BASE=1.0
# CIRCUIT_BREAKER_THRESHOLD=3
# CIRCUIT_BREAKER_COOLDOWN_MINUTES=10
# POISON_PILL_MAX_FAILURES=3
